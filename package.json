    "typecheck": "tsc -b",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
