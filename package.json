{
  "name": "ai-knowledge-compiler",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "pnpm -r build",
    "bench": "pnpm --filter @akb/search-engine bench",
